# ==========================================================================
#  Product Catalogue — root .gitignore
#  Covers: Laravel backend, React/Vite frontend, and the Python PDF parser.
# ==========================================================================

# --------------------------------------------------------------------------
#  Operating system / editors
# --------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# IDEs (keep shared VS Code recommendations if you want — see negation below)
.idea/
.vscode/*
!.vscode/extensions.json
.fleet/
.nova/
.zed/
*.suo
*.sln
*.njsproj
*.ntvs*

# --------------------------------------------------------------------------
#  Python (virtualenv + parser artifacts)
# --------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.Python
pip-log.txt
.mypy_cache/
.pytest_cache/
.ipynb_checkpoints/

# --------------------------------------------------------------------------
#  Node / Frontend (React + Vite)   -> frontend/**
# --------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
.vite/
*.local

# JS package-manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp.*

# --------------------------------------------------------------------------
#  Laravel / Backend   -> backend/**
# --------------------------------------------------------------------------
/backend/vendor/
/backend/node_modules/

# Environment & secrets — NEVER commit these (commit .env.example instead)
/backend/.env
/backend/.env.backup
/backend/.env.production
/backend/auth.json

# Compiled / cached framework files
/backend/bootstrap/cache/*.php
/backend/storage/*.key
/backend/storage/pail
/backend/.phpunit.result.cache
/backend/.phpunit.cache/
/backend/.phpactor.json

# Build output & the storage symlink
/backend/public/build/
/backend/public/hot
/backend/public/storage

# Logs
*.log

# Local SQLite database (this project uses MySQL; ignore any stray sqlite files)
/backend/database/*.sqlite
/backend/database/*.sqlite-journal

# Homestead
Homestead.json
Homestead.yaml

# --------------------------------------------------------------------------
#  Runtime / user-generated data (regenerated by import & seeder)
#  Uploaded PDFs and images extracted from them should not be in the repo.
# --------------------------------------------------------------------------
/backend/storage/app/private/imports/
/backend/storage/app/public/products/

# ==========================================================================
#  KEPT ON PURPOSE (do NOT ignore — needed to run/seed the app):
#   - /sample_pdf/product_catalog_v2.pdf   (used by the database seeder)
#   - /backend/.env.example
#   - /backend/scripts/import_products_from_pdf.py
#   - inspect_*.py helper scripts
#   - package.json / package-lock.json / composer.json / composer.lock
# ==========================================================================
